# Copy to .env. Never commit .env (gitignored).

# Notion integration token. Format: ntn_xxxx... (OAuth) or secret_xxxx... (internal integration).
NOTION_API_KEY=

# Root page where the entire OS will be provisioned. Create one page in your
# target Notion workspace, share it with the integration, then paste its ID here.
NOTION_ROOT_PAGE_ID=

# Optional — override config file location
CLIENT_CONFIG_PATH=./client.config.yaml
